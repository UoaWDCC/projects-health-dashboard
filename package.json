{
  "name": "projects-health-dashboard",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "dotenv -e .env -- pnpm --filter @repo/db db:generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @repo/db db:migrate",
    "db:studio": "dotenv -e .env -- pnpm --filter @repo/db db:studio"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "dotenv-cli": "^8.0.0",
    "prettier": "^3.5.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  }
}
