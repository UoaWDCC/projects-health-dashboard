# ─── Supabase ────────────────────────────────────────────────────────────────
# From: Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Database (Prisma) ────────────────────────────────────────────────────────
# Use the Supabase connection pooler URL (port 6543) for DATABASE_URL
# Use the direct connection URL (port 5432) for DIRECT_URL (migrations)
DATABASE_URL=
DIRECT_URL=

# ─── GitHub App ───────────────────────────────────────────────────────────────
# From: GitHub Developer Settings → GitHub Apps
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# ─── Discord Bot ──────────────────────────────────────────────────────────────
# From: Discord Developer Portal → Bot → Token
DISCORD_BOT_TOKEN=

# ─── LLM ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
