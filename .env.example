# ─── Supabase ────────────────────────────────────────────────────────────────
# From: Supabase dashboard → Project Settings → API Keys
# "Publishable key" → NEXT_PUBLIC_SUPABASE_ANON_KEY
# "Secret key"      → SUPABASE_SERVICE_ROLE_KEY
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<key>
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<key>

# ─── Database (Prisma) ────────────────────────────────────────────────────────
# From: Supabase dashboard → NavBar → Connect → Connection String
#
# DATABASE_URL: Method = "Transaction pooler" — port 6543
#   Used for runtime queries. Transaction mode does not support prepared
#   statements, which is why a separate DIRECT_URL is needed for migrations.
#
# DIRECT_URL: Method = "Session pooler" — port 5432
#   Used by Prisma for migrations only. Use Session pooler (not Direct
#   connection) — the free tier's direct connection is IPv6-only, while the
#   session pooler is IPv4-compatible and behaves identically for migrations.
#
# Replace [YOUR-PASSWORD] with your database password in both strings.
DATABASE_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres

# ─── GitHub App ───────────────────────────────────────────────────────────────
# From: GitHub Developer Settings → GitHub Apps
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# ─── Discord Bot ──────────────────────────────────────────────────────────────
# From: Discord Developer Portal → Bot → Token
DISCORD_BOT_TOKEN=
# From: Discord → Server Settings → Widget → Server ID (or right-click server with Developer Mode on)
DISCORD_GUILD_ID=

# ─── LLM ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
